# ============================================
# Environment Variables
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Phases 1-4: No API key needed (runs entirely on local Ollama)
# Phases 5-8: Requires OPENROUTER_API_KEY (free tier available)
# ============================================

# OpenRouter API Key (free at https://openrouter.ai/keys)
# Required for Phases 5-8 (cloud LLM for RAG, agents, multi-agent)
OPENROUTER_API_KEY=your-openrouter-api-key-here
